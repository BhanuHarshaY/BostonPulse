# Ticketmaster Discovery API — free: https://developer.ticketmaster.com/
TICKETMASTER_API_KEY=

# Override the reasoning engine (default: tim-gpt)
# Options: tim, tim-gpt, tim-edge, tim-gpt-heavy
# SUBCONSCIOUS_ENGINE=tim-gpt
